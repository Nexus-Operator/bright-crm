# Database (SQLite by default, switch to Postgres by changing DATABASE_URL)
DATABASE_URL="file:./dev.db"

# NextAuth.js
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth2 (Gmail + Calendar integration)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Twilio (Phone + SMS integration)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Dialpad (Cloud phone + SMS integration)
# Create at: https://developers.dialpad.com/docs/oauth2
DIALPAD_CLIENT_ID=""
DIALPAD_CLIENT_SECRET=""
# Optional: CTI Mini Dialer app ID for embedded dialer
# Create at: https://developers.dialpad.com/docs/mini-dialer
DIALPAD_CTI_CLIENT_ID=""
